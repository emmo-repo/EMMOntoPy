# EMMOntoPy ontokit Configuration File Template
#
# This file configures the ontokit automation tools for your ontology project.
# Uncomment and adjust settings as needed for your specific project.

# ============================================================================
# REQUIRED CONFIGURATION, CAN BE GENERATED WITH ONTOKIT SETUP
# ============================================================================

# Name of the ontology (used as identifier in documentation, CI/CD, etc.)
ONTOLOGY_NAME: demo

# Namespace prefix for the ontology (e.g., "emmo", "demo")
ONTOLOGY_PREFIX: demo

# Base IRI of the ontology
ONTOLOGY_IRI: https://w3id.org/demo/

# Repository in format "owner/repo"
# (used for CI/CD workflows, issue tracking, pull requests)
GIT_REPOSITORY: user/demo-ontology

# Git server base host or URL (for example github.com, gitlab.com,
# git.company.com or https://git.company.com)
GIT_BASE_URL: github.com

# Legacy alias kept for backward compatibility.
# GITHUB_REPOSITORY: user/demo-ontology

# Build output directory (relative path recommended)
BUILD_DIR: build

# ============================================================================
# OPTIONAL: DOCUMENTATION SETTINGS
# ============================================================================

# Title for generated documentation (used in RST headers, HTML titles, etc.)
# DOCUMENTATION_TITLE: Demo Ontology Reference

# Directory containing documentation source files (Markdown, RST, etc.)
# DOCUMENTATION_DIR: docs

# ============================================================================
# OPTIONAL: MODULAR DOCUMENTATION PAGES
# ============================================================================
#
# DOC_PAGES defines which reference documentation pages to generate and
# which ontologies each page should include. Each page becomes a separate
# RST file that can be referenced from multiple index pages.
#
# - id: Unique identifier for the reference page (used in DOC_INDEXES entries)
# - title: Display title for the page (shown in navigation/menus)
# - header_title: Custom header title for the RST document
# - output: Output path relative to PUBLIC dir
# - ontologies: List of ontologies to include
#   * "main" = the primary ontology
#   * "ontology_name" = imported ontology by name
#   * "https://w3id.org/..." = imported ontology by IRI
#   * "/path/to/file.ttl" = imported ontology by file path
#   * imported: true/false (whether to include imported ontologies, default: true)
#
# Example with multiple reference pages:

DOC_PAGES:
  - id: full-reference
    title: Full Reference
    header_title: Full Reference
    output: api_reference/full.rst
    ontologies:
      - main
      - imported

  - id: core-reference
    title: Core Ontology Reference
    header_title: Core Ontology
    output: api_reference/core.rst
    ontologies:
      - main

# ============================================================================
# OPTIONAL: MODULAR DOCUMENTATION INDEXES
# ============================================================================
#
# DOC_INDEXES defines documentation landing pages that curate and link to
# reference pages. This allows you to:
# - Create multiple entry points for documentation
# - Link indexes to other indexes or reference pages
# - Include/exclude README files
# - Sort and customize displayed entries
#
# - id: Unique identifier for the index page
# - title: Index page title (shown in RST header)
# - output: Output path relative to BUILD_DIR
# - include_readme: Whether to prepend README.md content (true/false)
# - readme_path: Path to README relative to BUILD_DIR (default: ../README.md)
# - hidden: Whether to hide from toctree (for sidebar nav, default: false)
# - entries: List of entries linking to reference pages or other indexes
#   * target: id of the target page (from DOC_PAGES or DOC_INDEXES)
#   * title: Display label for the link
#
# Example with navigation structure:

DOC_INDEXES:
  - id: main-index
    title: Documentation
    output: index.rst
    include_readme: true
    entries:
      - target: full-reference
        title: Full Reference

      - target: core-reference
        title: Core Ontology

  - id: api-reference
    title: API Reference
    output: api_reference/index.rst
    include_readme: false
    hidden: false
